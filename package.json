{
  "name": "form-fit-ai",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo prebuild --clean && expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo prebuild --clean && ./android/gradlew -p android assembleRelease",
    "install-apk": "adb install ./android/app/build/outputs/apk/release/app-release.apk",
    "build:install-apk": "bun run build && bun run install-apk",
    "doctor": "expo-doctor --verbose",
    "update-packages": "expo install --check",
    "reinstall-packages": "rm -rf node_modules bun.lock && bun i",
    "lint": "biome check",
    "format": "biome format",
    "check": "biome check",
    "clean": "biome check --write",
    "reset-project": "node ./scripts/reset-project.js",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "3.4.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/react": "~19.1.0",
    "lefthook": "^2.1.6",
    "postcss": "8.4.49",
    "typescript": "~5.9.2"
  },
  "private": true
}
